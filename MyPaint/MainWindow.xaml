<Window x:Class="MyPaint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPaint" Height="600" Width="800"
        KeyDown="Window_KeyDown"
        Background="#333">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <!-- Панель инструментов -->
            <ColumnDefinition Width="*"/>
            <!-- Холст -->
            <ColumnDefinition Width="200"/>
            <!-- Слои -->
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <StackPanel Grid.Column="0" Background="#444">
            <Button Content="🖱️" Height="40" Margin="5" Click="Tool_Click" Tag="Select" ToolTip="Выделение"/>
            <Button Content="📏" Height="40" Margin="5" Click="Tool_Click" Tag="Line" ToolTip="Линия"/>
            <Button Content="〰️" Height="40" Margin="5" Click="Tool_Click" Tag="Polyline" ToolTip="Ломаная"/>
            <Button Content="⬜" Height="40" Margin="5" Click="Tool_Click" Tag="Rect" ToolTip="Прямоугольник"/>
            <Button Content="⚪" Height="40" Margin="5" Click="Tool_Click" Tag="Ellipse" ToolTip="Эллипс"/>
            <Button Content="📐" Height="40" Margin="5" Click="Tool_Click" Tag="Polygon" ToolTip="Многоугольник"/>
            <Separator Margin="5" Background="#666"/>
            <Button Content="🗑️" Height="40" Margin="5" Click="Delete_Click" ToolTip="Удалить (Del)"/>

            <Label Content="Цвет: " FontWeight="Bold" Foreground="White"/>
            <UniformGrid Columns="4" x:Name="ColorPalette">
                <Button Background="Black" Tag="Black" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Red" Tag="Red" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Green" Tag="Green" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Blue" Tag="Blue" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Yellow" Tag="Yellow" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Orange" Tag="Orange" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="White" Tag="White" Click="Color_Click" Height="25" Margin="2"/>
                <Button Background="Gray" Tag="Gray" Click="Color_Click" Height="25" Margin="2"/>
            </UniformGrid>
            <Button Content="Другой ..." Margin="0,5,0,0" Click="MoreColors_Click"/>
            <Rectangle x:Name="CurrentColorRect" Height="10" Fill="Black" Margin="0,5,0,0"/>

            <Separator Margin="5" Background="#666"/>
            <Label Content="Толщ:" Foreground="White" HorizontalAlignment="Center" Padding="0"/>
            <TextBlock Text="{Binding ElementName=ThicknessSlider, Path=Value}" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>

            <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="30" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" 
        Margin="5,0"   ValueChanged="ThicknessSlider_ValueChanged"/>

            <Separator Margin="5,10,5,5" Background="#666"/>
            <Label Content="ЗАЛИВКА" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Padding="0"/>

            <Grid Margin="5,2">
                <Rectangle x:Name="CurrentFillRect" Height="25" Fill="Transparent" Stroke="White" StrokeDashArray="2 2"/>
                <TextBlock x:Name="FillStatusText" Text="Прозрачно" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" IsHitTestVisible="False"/>
            </Grid>

            <UniformGrid Columns="2" Margin="5,2">
                <Button Content="Взять цвет" Click="SetFillColor_Click" ToolTip="Сделать основной цвет цветом заливки" Margin="2"/>
                <Button Content="❌" Click="ClearFill_Click" ToolTip="Убрать заливку" Margin="2"/>
            </UniformGrid>

            <Button Content="🪣 Залить выделенное" Margin="5,2" Click="ApplyFillToSelected_Click" Height="30" Background="#446644" Foreground="White"/>
        </StackPanel>




        <!-- ЦЕНТРАЛЬНЫЙ ХОЛСТ -->
        <Border Grid.Column="1" Background="White" Margin="10" ClipToBounds="True">
            <Image x:Name="CanvasImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   MouseDown="Canvas_MouseDown"
                   MouseMove="Canvas_MouseMove"
                   MouseUp="Canvas_MouseUp"
                   MouseRightButtonDown="Canvas_MouseRightButtonDown" />
        </Border>

        <!-- ПРАВАЯ ПАНЕЛЬ (СЛОИ) -->
        <Grid Grid.Column="2" Background="#444">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Content="СЛОИ" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" Margin="5"/>

            <ListBox x:Name="LayersList" SelectionChanged="LayersList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsVisible}" Click="LayerCheckBox_Click" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>




            <UniformGrid Grid.Row="2" Columns="2" Margin="5">
                <Button Content="➕ Добавить" Margin="2" Padding="5" Background="#3B7A3B"   Foreground="White" BorderThickness="0" Click="AddLayer_Click" Height="35"/>

                <Button Content="➖ Удалить" Margin="2" Padding="5" Background="#A33636" Foreground="White" BorderThickness="0" Click="DeleteLayer_Click" Height="35"/>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>
